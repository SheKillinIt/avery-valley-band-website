{
  "name": "avery-valley-band-website",
  "version": "1.0.0",
  "description": "Fully customizable website for Avery Valley Band with admin dashboard, booking calendar, and merch store",
  "main": "server/index.js",
  "scripts": {
    "start": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node server/index.js",
    "client": "cd client && npm start",
    "dev": "concurrently \"nodemon server/index.js\" \"cd client && npm start\"",
    "build": "cd client && npm run build"
  },
  "dependencies": {
    "express": "^4.18.2",
    "mongoose": "^7.0.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.0",
    "dotenv": "^16.0.3",
    "nodemailer": "^6.9.1",
    "stripe": "^12.0.0",
    "cors": "^2.8.5",
    "multer": "^1.4.5-lts.1",
    "cloudinary": "^1.35.0"
  },
  "devDependencies": {
    "nodemon": "^2.0.20",
    "concurrently": "^8.0.1"
  }
}
